# 한국은행 ECOS API
ECOS_API_KEY=your_ecos_api_key_here

# 미국 FRED API (거시지표)
FRED_API_KEY=your_fred_api_key_here

# Snowflake dual-write
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=FDE_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=your_warehouse

# Telegram 알림 (scripts/auto_market.py)
# 1. @BotFather 에서 봇 생성 → BOT_TOKEN 발급
# 2. 봇에게 메시지 보낸 뒤 https://api.telegram.org/bot<TOKEN>/getUpdates 로 CHAT_ID 확인
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
